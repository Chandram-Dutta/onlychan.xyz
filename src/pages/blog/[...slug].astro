---
import { getCollection, render } from "astro:content";
import "../../styles/global.css";
import SEO from "../../components/SEO.astro";
import SpecialQuote from "../../components/SpecialQuote.astro";
import Tldraw from "../../components/Tldraw.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={post.data.description} />
        <title>{post.data.title} | onlychan</title>
        <SEO
            title={`${post.data.title} | onlychan`}
            description={post.data.description}
            image={post.data.image}
            slug={post.id}
            type="article"
        />
        <script>
            if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                document.documentElement.classList.add("dark");
            }
        </script>
        <script>
            import mermaid from "mermaid";

            const isDark = document.documentElement.classList.contains("dark");
            mermaid.initialize({
                startOnLoad: false,
                theme: isDark ? "dark" : "default",
            });

            document.addEventListener("DOMContentLoaded", async () => {
                const blocks = document.querySelectorAll(
                    "pre[data-language='mermaid']",
                );
                let counter = 0;
                for (const pre of blocks) {
                    const diagram = pre.textContent ?? "";
                    const id = `mermaid-${counter++}`;
                    const { svg } = await mermaid.render(id, diagram);
                    const wrapper = document.createElement("div");
                    wrapper.className = "mermaid-diagram";
                    wrapper.innerHTML = svg;
                    pre.replaceWith(wrapper);
                }
            });
        </script>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const overlay =
                    document.getElementById("lightbox-overlay");
                if (!overlay) return;
                const stage = overlay.querySelector<HTMLDivElement>(
                    ".lightbox-stage",
                );
                if (!stage) return;

                const openWith = (node: HTMLElement) => {
                    stage.replaceChildren(node);
                    overlay.classList.add("open");
                    document.body.style.overflow = "hidden";
                };
                const close = () => {
                    overlay.classList.remove("open");
                    stage.replaceChildren();
                    document.body.style.overflow = "";
                };

                // tldraw expand buttons — use native Fullscreen API on the figure
                document
                    .querySelectorAll<HTMLButtonElement>(".tldraw-expand")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const figure = btn.closest<HTMLElement>(".tldraw-embed");
                            figure?.requestFullscreen?.();
                        });
                    });

                // expandable images (skip ones wrapped in a link)
                document
                    .querySelectorAll<HTMLImageElement>(".prose img")
                    .forEach((img) => {
                        if (img.closest("a")) return;
                        img.style.cursor = "zoom-in";
                        img.addEventListener("click", () => {
                            const full = document.createElement("img");
                            full.src = img.currentSrc || img.src;
                            full.alt = img.alt;
                            full.className = "lightbox-img";
                            openWith(full);
                        });
                    });

                overlay.addEventListener("click", (e) => {
                    if (
                        e.target === overlay ||
                        (e.target as HTMLElement).closest(".lightbox-close")
                    ) {
                        close();
                    }
                });
                document.addEventListener("keydown", (e) => {
                    if (e.key === "Escape" && overlay.classList.contains("open"))
                        close();
                });
            });
        </script>
    </head>
    <body
        class="font-serif bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 min-h-screen relative overflow-x-hidden [&_a]:text-(--link-accent) [&_a:hover]:text-(--link-accent-hover) dark:[&_a]:text-(--link-accent-dark) dark:[&_a:hover]:text-(--link-accent-dark-hover)"
    >
        <div class="mx-auto max-w-4xl p-4 md:px-8 lg:px-12 relative z-10">
            <a href="/blog" class="text-sm opacity-70">← all posts</a>
            <article class="pt-4">
                <header
                    class="pb-6 border-b border-neutral-200 dark:border-neutral-800"
                >
                    <h1
                        class="font-bold text-3xl md:text-4xl font-instrument-serif"
                    >
                        {post.data.title}
                    </h1>
                    <p class="text-sm opacity-60 mt-2">
                        {
                            post.data.pubDate.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })
                        }
                    </p>
                    <div class="flex gap-2 mt-3 flex-wrap">
                        {
                            post.data.tags.map((tag) => (
                                <span class="text-xs px-2 py-0.5 bg-neutral-200 dark:bg-neutral-800 rounded">
                                    {tag}
                                </span>
                            ))
                        }
                    </div>
                </header>
                <div
                    class="prose prose-neutral dark:prose-invert max-w-none pt-6
 prose-headings:font-instrument-serif prose-headings:font-bold
 prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg
  prose-li:my-1
 prose-p:leading-relaxed"
                >
                    <Content components={{ SpecialQuote, Tldraw }} />
                </div>
            </article>
        </div>
        <div id="lightbox-overlay" role="dialog" aria-modal="true">
            <button
                type="button"
                class="lightbox-close"
                aria-label="Close"
                title="Close">&times;</button>
            <div class="lightbox-stage"></div>
        </div>
    </body>
</html>

<style>
    :global(.prose code::before),
    :global(.prose code::after) {
        content: none !important;
    }
    :global(.prose .katex-display) {
        text-align: center !important;
    }
    article {
        padding-bottom: 5rem;
    }
    @media (min-width: 768px) {
        article {
            padding-bottom: 6rem;
        }
    }
    :global(.mermaid-diagram) {
        display: flex;
        justify-content: center;
        margin: 1.5rem 0;
    }
    :global(.mermaid-diagram svg) {
        max-width: 100%;
        height: auto;
    }
    #lightbox-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(4px);
    }
    #lightbox-overlay.open {
        display: flex;
    }
    .lightbox-stage {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    :global(.lightbox-img) {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 0.5rem;
        cursor: zoom-out;
    }
    .lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 2.5rem;
        height: 2.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        line-height: 1;
        color: #fff;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 9999px;
        cursor: pointer;
    }
    .lightbox-close:hover {
        background: rgba(255, 255, 255, 0.22);
    }
</style>
