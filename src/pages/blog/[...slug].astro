---
import { getCollection, render } from "astro:content";
import "../../styles/global.css";
import SEO from "../../components/SEO.astro";
import SpecialQuote from "../../components/SpecialQuote.astro";
import Tldraw from "../../components/Tldraw.astro";

export async function getStaticPaths() {
    const posts = await getCollection("blog");
    return posts.map((post) => ({
        params: { slug: post.id },
        props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={post.data.description} />
        <title>{post.data.title} | onlychan</title>
        <SEO
            title={`${post.data.title} | onlychan`}
            description={post.data.description}
            image={post.data.image}
            slug={post.id}
            type="article"
        />
        <script>
            if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
                document.documentElement.classList.add("dark");
            }
        </script>
        <script>
            import mermaid from "mermaid";

            const isDark = document.documentElement.classList.contains("dark");

            // Match the blog's palette: serif type, teal accent edges,
            // soft neutral nodes instead of mermaid's stock lavender.
            const light = {
                background: "#ffffff",
                primaryColor: "#f5f5f5",
                primaryTextColor: "#171717",
                primaryBorderColor: "#d4d4d4",
                secondaryColor: "#fafafa",
                tertiaryColor: "#fafafa",
                lineColor: "#0f766e",
                edgeLabelBackground: "#ffffff",
            };
            const dark = {
                background: "#171717",
                primaryColor: "#262626",
                primaryTextColor: "#f5f5f5",
                primaryBorderColor: "#404040",
                secondaryColor: "#1f1f1f",
                tertiaryColor: "#1f1f1f",
                lineColor: "#2dd4bf",
                edgeLabelBackground: "#171717",
            };

            const sans =
                'ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif';

            mermaid.initialize({
                startOnLoad: false,
                theme: "base",
                fontFamily: sans,
                themeVariables: {
                    fontFamily: sans,
                    fontSize: "15px",
                    ...(isDark ? dark : light),
                },
                flowchart: {
                    curve: "basis",
                    nodeSpacing: 50,
                    rankSpacing: 60,
                    padding: 16,
                    useMaxWidth: true,
                },
            });

            document.addEventListener("DOMContentLoaded", async () => {
                // Mermaid measures node widths from the rendered font, so wait
                // for fonts to settle before rendering or text gets clipped.
                if (document.fonts?.ready) {
                    await document.fonts.ready;
                }
                const blocks = document.querySelectorAll(
                    "pre[data-language='mermaid']",
                );
                let counter = 0;
                for (const pre of blocks) {
                    const diagram = pre.textContent ?? "";
                    const id = `mermaid-${counter++}`;
                    const { svg } = await mermaid.render(id, diagram);
                    const wrapper = document.createElement("div");
                    wrapper.className = "mermaid-diagram";
                    wrapper.innerHTML = svg;
                    pre.replaceWith(wrapper);
                }
            });
        </script>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const overlay =
                    document.getElementById("lightbox-overlay");
                if (!overlay) return;
                const stage = overlay.querySelector<HTMLDivElement>(
                    ".lightbox-stage",
                );
                if (!stage) return;

                const openWith = (node: HTMLElement) => {
                    stage.replaceChildren(node);
                    overlay.classList.add("open");
                    document.body.style.overflow = "hidden";
                };
                const close = () => {
                    overlay.classList.remove("open");
                    stage.replaceChildren();
                    document.body.style.overflow = "";
                };

                // tldraw expand buttons — use native Fullscreen API on the figure
                document
                    .querySelectorAll<HTMLButtonElement>(".tldraw-expand")
                    .forEach((btn) => {
                        btn.addEventListener("click", () => {
                            const figure = btn.closest<HTMLElement>(".tldraw-embed");
                            figure?.requestFullscreen?.();
                        });
                    });

                // expandable images (skip ones wrapped in a link)
                document
                    .querySelectorAll<HTMLImageElement>(".prose img")
                    .forEach((img) => {
                        if (img.closest("a")) return;
                        img.style.cursor = "zoom-in";
                        img.addEventListener("click", () => {
                            const full = document.createElement("img");
                            full.src = img.currentSrc || img.src;
                            full.alt = img.alt;
                            full.className = "lightbox-img";
                            openWith(full);
                        });
                    });

                overlay.addEventListener("click", (e) => {
                    if (
                        e.target === overlay ||
                        (e.target as HTMLElement).closest(".lightbox-close")
                    ) {
                        close();
                    }
                });
                document.addEventListener("keydown", (e) => {
                    if (e.key === "Escape" && overlay.classList.contains("open"))
                        close();
                });
            });
        </script>
        <script>
            document.addEventListener("DOMContentLoaded", () => {
                const headings = Array.from(
                    document.querySelectorAll<HTMLElement>(
                        ".prose h1, .prose h2, .prose h3",
                    ),
                );

                const desktop = document.getElementById("toc-desktop");
                const toggle = document.getElementById("toc-toggle");
                const drawer = document.getElementById("toc-drawer");
                const listDesktop =
                    document.getElementById("toc-list-desktop");
                const listMobile = document.getElementById("toc-list-mobile");

                // Short posts don't need a TOC.
                if (
                    headings.length < 2 ||
                    !listDesktop ||
                    !listMobile ||
                    !drawer ||
                    !toggle
                ) {
                    return;
                }

                const slugify = (text: string) =>
                    text
                        .toLowerCase()
                        .trim()
                        .replace(/[^a-z0-9\s-]/g, "")
                        .replace(/\s+/g, "-")
                        .replace(/-+/g, "-")
                        .replace(/^-|-$/g, "") || "section";

                // Assign stable, de-duplicated ids to every heading.
                const seen = new Map<string, number>();
                const entries = headings.map((el) => {
                    if (!el.id) {
                        let base = slugify(el.textContent ?? "");
                        const count = seen.get(base) ?? 0;
                        seen.set(base, count + 1);
                        el.id = count === 0 ? base : `${base}-${count}`;
                    }
                    return {
                        id: el.id,
                        text: el.textContent ?? "",
                        level: Number(el.tagName.substring(1)),
                        el,
                    };
                });

                // id -> all anchor links pointing at it (desktop + mobile).
                const linksById = new Map<string, HTMLAnchorElement[]>();

                const buildList = (container: HTMLElement) => {
                    const ul = document.createElement("ul");
                    ul.className = "toc-ul";
                    for (const entry of entries) {
                        const li = document.createElement("li");
                        const a = document.createElement("a");
                        a.href = `#${entry.id}`;
                        a.textContent = entry.text;
                        a.className = "toc-link";
                        a.dataset.level = String(entry.level);
                        a.addEventListener("click", (e) => {
                            e.preventDefault();
                            history.pushState(null, "", `#${entry.id}`);
                            entry.el.scrollIntoView({ behavior: "smooth" });
                            closeDrawer();
                        });
                        const arr = linksById.get(entry.id) ?? [];
                        arr.push(a);
                        linksById.set(entry.id, arr);
                        li.appendChild(a);
                        ul.appendChild(li);
                    }
                    container.replaceChildren(ul);
                };

                buildList(listDesktop);
                buildList(listMobile);

                // Reveal the now-populated controls.
                desktop?.removeAttribute("hidden");
                toggle.removeAttribute("hidden");

                // --- Mobile drawer open/close ---
                const openDrawer = () => {
                    drawer.classList.add("open");
                    toggle.setAttribute("aria-expanded", "true");
                    document.body.style.overflow = "hidden";
                };
                function closeDrawer() {
                    drawer.classList.remove("open");
                    toggle.setAttribute("aria-expanded", "false");
                    document.body.style.overflow = "";
                }
                toggle.addEventListener("click", openDrawer);
                drawer.addEventListener("click", (e) => {
                    const target = e.target as HTMLElement;
                    if (target === drawer || target.closest(".toc-close")) {
                        closeDrawer();
                    }
                });
                document.addEventListener("keydown", (e) => {
                    if (e.key === "Escape" && drawer.classList.contains("open"))
                        closeDrawer();
                });

                // --- Scroll-spy: highlight the current section ---
                let activeId = "";
                const setActive = (id: string) => {
                    if (id === activeId) return;
                    if (activeId) {
                        linksById
                            .get(activeId)
                            ?.forEach((a) =>
                                a.removeAttribute("aria-current"),
                            );
                    }
                    activeId = id;
                    linksById
                        .get(id)
                        ?.forEach((a) =>
                            a.setAttribute("aria-current", "true"),
                        );
                };

                const observer = new IntersectionObserver(
                    (observed) => {
                        const visible = observed
                            .filter((e) => e.isIntersecting)
                            .sort(
                                (a, b) =>
                                    a.boundingClientRect.top -
                                    b.boundingClientRect.top,
                            );
                        if (visible.length > 0) {
                            setActive(visible[0].target.id);
                        }
                    },
                    { rootMargin: "0px 0px -70% 0px", threshold: 0 },
                );
                entries.forEach((entry) => observer.observe(entry.el));

                // --- Deep-link: scroll to hash on load (ids are JS-assigned) ---
                if (location.hash) {
                    const target = document.getElementById(
                        decodeURIComponent(location.hash.slice(1)),
                    );
                    if (target) {
                        requestAnimationFrame(() =>
                            target.scrollIntoView({ behavior: "instant" as ScrollBehavior }),
                        );
                        setActive(target.id);
                    }
                }
            });
        </script>
    </head>
    <body
        class="font-serif bg-white dark:bg-neutral-900 text-neutral-900 dark:text-neutral-100 min-h-screen relative overflow-x-hidden [&_a]:text-(--link-accent) [&_a:hover]:text-(--link-accent-hover) dark:[&_a]:text-(--link-accent-dark) dark:[&_a:hover]:text-(--link-accent-dark-hover)"
    >
        <div class="mx-auto max-w-4xl p-4 md:px-8 lg:px-12 relative z-10">
            <a href="/blog" class="text-sm opacity-70">← all posts</a>
            <article class="pt-4">
                <header
                    class="pb-6 border-b border-neutral-200 dark:border-neutral-800"
                >
                    <h1
                        class="font-bold text-3xl md:text-4xl font-instrument-serif"
                    >
                        {post.data.title}
                    </h1>
                    <p class="text-sm opacity-60 mt-2">
                        {
                            post.data.pubDate.toLocaleDateString("en-US", {
                                year: "numeric",
                                month: "long",
                                day: "numeric",
                            })
                        }
                    </p>
                    <div class="flex gap-2 mt-3 flex-wrap">
                        {
                            post.data.tags.map((tag) => (
                                <span class="text-xs px-2 py-0.5 bg-neutral-200 dark:bg-neutral-800 rounded">
                                    {tag}
                                </span>
                            ))
                        }
                    </div>
                </header>
                <div
                    class="prose prose-neutral dark:prose-invert max-w-none pt-6
 prose-headings:font-instrument-serif prose-headings:font-bold
 prose-h1:text-2xl prose-h2:text-xl prose-h3:text-lg
  prose-li:my-1
 prose-p:leading-relaxed"
                >
                    <Content components={{ SpecialQuote, Tldraw }} />
                </div>
            </article>
        </div>

        <!-- Desktop table of contents (left margin, large screens only) -->
        <aside
            id="toc-desktop"
            class="hidden xl:flex flex-col fixed top-24 left-5 2xl:left-12 w-48 2xl:w-56 max-h-[70vh] z-20"
            hidden
        >
            <p
                class="text-xs uppercase tracking-wider opacity-50 mb-3 font-instrument-serif"
            >
                Contents
            </p>
            <nav
                id="toc-list-desktop"
                class="toc-nav overflow-y-auto pr-2 text-sm leading-snug"
            >
            </nav>
        </aside>

        <!-- Mobile table of contents toggle + drawer -->
        <button
            id="toc-toggle"
            type="button"
            class="xl:hidden fixed bottom-6 right-6 z-40 inline-flex items-center gap-2 rounded-full px-4 py-2.5 text-sm font-medium shadow-lg bg-neutral-900 text-white dark:bg-neutral-100 dark:text-neutral-900"
            aria-label="Open table of contents"
            aria-expanded="false"
            aria-controls="toc-drawer"
            hidden
        >
            <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
            >
                <line x1="8" y1="6" x2="21" y2="6"></line>
                <line x1="8" y1="12" x2="21" y2="12"></line>
                <line x1="8" y1="18" x2="21" y2="18"></line>
                <line x1="3" y1="6" x2="3.01" y2="6"></line>
                <line x1="3" y1="12" x2="3.01" y2="12"></line>
                <line x1="3" y1="18" x2="3.01" y2="18"></line>
            </svg>
            Contents
        </button>
        <div id="toc-drawer" role="dialog" aria-modal="true" aria-label="Table of contents">
            <div class="toc-panel">
                <div class="flex items-center justify-between mb-4">
                    <p
                        class="text-xs uppercase tracking-wider opacity-50 font-instrument-serif"
                    >
                        Contents
                    </p>
                    <button
                        type="button"
                        class="toc-close"
                        aria-label="Close"
                        title="Close">&times;</button>
                </div>
                <nav
                    id="toc-list-mobile"
                    class="toc-nav overflow-y-auto text-sm leading-snug"
                >
                </nav>
            </div>
        </div>

        <div id="lightbox-overlay" role="dialog" aria-modal="true">
            <button
                type="button"
                class="lightbox-close"
                aria-label="Close"
                title="Close">&times;</button>
            <div class="lightbox-stage"></div>
        </div>
    </body>
</html>

<style>
    :global(.prose code::before),
    :global(.prose code::after) {
        content: none !important;
    }
    :global(.prose .katex-display) {
        text-align: center !important;
    }
    :global(.prose img) {
        border-radius: 0.5rem;
    }
    article {
        padding-bottom: 5rem;
    }
    @media (min-width: 768px) {
        article {
            padding-bottom: 6rem;
        }
    }
    :global(.mermaid-diagram) {
        display: flex;
        justify-content: center;
        margin: 2rem 0;
    }
    :global(.mermaid-diagram svg) {
        max-width: 100%;
        height: auto;
    }
    /* Soften the boxy default nodes to match the site's rounded surfaces. */
    :global(.mermaid-diagram .node rect),
    :global(.mermaid-diagram .node polygon) {
        rx: 8px;
        ry: 8px;
    }
    :global(.mermaid-diagram .edgePaths path) {
        stroke-width: 1.5px;
    }
    /* Keep edge labels readable and integrated with the prose. */
    :global(.mermaid-diagram .edgeLabel) {
        font-size: 0.8125rem;
        font-style: italic;
    }
    #lightbox-overlay {
        position: fixed;
        inset: 0;
        z-index: 100;
        display: none;
        align-items: center;
        justify-content: center;
        padding: 2rem;
        background: rgba(0, 0, 0, 0.8);
        backdrop-filter: blur(4px);
    }
    #lightbox-overlay.open {
        display: flex;
    }
    .lightbox-stage {
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    :global(.lightbox-img) {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        border-radius: 0.5rem;
        cursor: zoom-out;
    }
    .lightbox-close {
        position: absolute;
        top: 1rem;
        right: 1rem;
        width: 2.5rem;
        height: 2.5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 1.75rem;
        line-height: 1;
        color: #fff;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 9999px;
        cursor: pointer;
    }
    .lightbox-close:hover {
        background: rgba(255, 255, 255, 0.22);
    }

    /* --- Table of contents --- */
    html {
        scroll-behavior: smooth;
    }
    :global(.prose :is(h1, h2, h3)) {
        scroll-margin-top: 2rem;
    }
    .toc-ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }
    :global(.toc-link) {
        display: block;
        text-decoration: none;
        color: inherit;
        opacity: 0.6;
        border-left: 2px solid transparent;
        padding: 0.15rem 0 0.15rem 0.75rem;
        transition: opacity 0.15s ease, color 0.15s ease;
    }
    :global(.toc-link:hover) {
        opacity: 1;
    }
    :global(.toc-link[data-level="2"]) {
        padding-left: 1.5rem;
    }
    :global(.toc-link[data-level="3"]) {
        padding-left: 2.25rem;
        font-size: 0.8125rem;
    }
    :global(.toc-link[aria-current="true"]) {
        opacity: 1;
        color: var(--link-accent);
        border-left-color: var(--link-accent);
    }
    :global(.dark .toc-link[aria-current="true"]) {
        color: var(--link-accent-dark);
        border-left-color: var(--link-accent-dark);
    }

    /* Mobile drawer */
    #toc-drawer {
        position: fixed;
        inset: 0;
        z-index: 90;
        display: none;
        background: rgba(0, 0, 0, 0.5);
        backdrop-filter: blur(4px);
    }
    #toc-drawer.open {
        display: block;
    }
    .toc-panel {
        position: absolute;
        top: 0;
        right: 0;
        height: 100%;
        width: min(20rem, 85vw);
        overflow-y: auto;
        padding: 1.5rem;
        background: #fff;
    }
    :global(.dark) .toc-panel {
        background: #171717;
    }
    .toc-close {
        font-size: 1.5rem;
        line-height: 1;
        opacity: 0.6;
        cursor: pointer;
        background: none;
        border: none;
        color: inherit;
    }
    .toc-close:hover {
        opacity: 1;
    }
</style>
